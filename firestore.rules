// ════════════════════════════════════════════════════════════════
// FIRESTORE SECURITY RULES — FIXED
// ════════════════════════════════════════════════════════════════
//
// HOW TO APPLY:
//   1. Go to https://console.firebase.google.com
//   2. Select project: vercitty-edu
//   3. Firestore Database → Rules tab
//   4. Replace ALL existing rules with the rules below
//   5. Click "Publish"
//
// ROOT CAUSE OF "Missing or insufficient permissions":
//   checkDuplicateEnrollment() uses a Firestore WHERE query.
//   WHERE queries are "list" operations. By default, unauthenticated
//   users cannot list the `students` collection.
//   The fix: allow individual reads + coupon reads for all users,
//   while keeping admin-only access for listing all students.
//
// ════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── STUDENTS ──────────────────────────────────────────────
    // - Anyone can CREATE (needed for enrollment after payment)
    // - Anyone can READ a single doc by studentId field (for student lookup page)
    // - LIST (query all) restricted to authenticated admins only
    // - UPDATE/DELETE restricted to authenticated admins only
    match /students/{docId} {
      allow create: if true;

      // Allow reading individual student docs (Student Lookup page)
      allow get: if true;

      // Allow listing (WHERE queries) only for authenticated users (admins)
      // This fixes "missing permissions" when checkDuplicateEnrollment() runs
      allow list: if request.auth != null;

      allow update, delete: if request.auth != null;
    }

    // ── COUPONS ───────────────────────────────────────────────
    // - Anyone can READ (needed for coupon validation on Apply page)
    // - Only admins can CREATE/UPDATE/DELETE
    match /coupons/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── COURSES ───────────────────────────────────────────────
    // - Anyone can READ (needed to populate course dropdown on Apply page)
    // - Only admins can CREATE/UPDATE/DELETE
    match /courses/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── BATCHES ───────────────────────────────────────────────
    // - Anyone can READ (for displaying batch info)
    // - Only admins can CREATE/UPDATE/DELETE
    match /batches/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── META (Student ID counter) ─────────────────────────────
    // - Anyone can read/write (needed for auto-incrementing student ID)
    // - This is safe because the counter only increments
    match /meta/{docId} {
      allow read, write: if true;
    }
  }
}
